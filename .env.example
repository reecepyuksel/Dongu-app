# Server Configuration
PORT=3005
NODE_ENV=development
JWT_SECRET=
# Comma-separated whitelist used by both HTTP and WebSocket CORS
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,http://127.0.0.1:3000
# Missing Origin policy for WebSocket CORS callback (recommended false in production)
ALLOW_MISSING_ORIGIN=true

# Database Configuration
DB_HOST=127.0.0.1
DB_PORT=5433
DB_USERNAME=postgres
DB_PASSWORD=
DB_NAME=loopp_db
TYPEORM_SYNCHRONIZE=true
THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=120

# Redis Configuration
REDIS_ENABLED=true
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_KEY_PREFIX=dongu:dev:

# Event Pipeline Controls
EVENT_RETRY_BATCH_SIZE=50
EVENT_RETRY_MAX_COUNT=10
EVENT_RETENTION_DAYS=90
NOTIFICATION_RETENTION_DAYS=180
DELETED_MESSAGE_RETENTION_DAYS=90
EVENT_DEAD_LETTER_RETENTION_DAYS=30

# Read-path Feature Flags
USE_REDIS_UNREAD_COUNT=false
USE_TIMESCALE_LEADERBOARD=false
USE_EVENT_BASED_METRICS=false

# Debug Logging Controls
WS_DEBUG_LOGS=false
LOG_TRADE_OFFERS_DEBUG=false

# Suggested overrides by environment
# development:
# USE_REDIS_UNREAD_COUNT=false
# USE_EVENT_BASED_METRICS=false
# EVENT_RETENTION_DAYS=14
#
# staging:
# USE_REDIS_UNREAD_COUNT=true
# USE_EVENT_BASED_METRICS=true
# EVENT_RETENTION_DAYS=30
#
# production:
# USE_REDIS_UNREAD_COUNT=true
# USE_EVENT_BASED_METRICS=true
# EVENT_RETENTION_DAYS=90
# NOTIFICATION_RETENTION_DAYS=180
# DELETED_MESSAGE_RETENTION_DAYS=90
# EVENT_DEAD_LETTER_RETENTION_DAYS=30

# Ops Endpoint Security
OPS_STATUS_TOKEN=

# Cloudinary Configuration
# Not: Upload fallback to local disk kapalıdır. Bu alanlardan biri zorunludur:
# 1) CLOUDINARY_URL
# 2) CLOUDINARY_CLOUD_NAME + CLOUDINARY_API_KEY + CLOUDINARY_API_SECRET
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_URL=
