# Server Configuration
PORT=3005
NODE_ENV=development
JWT_SECRET=

# Database Configuration
DB_HOST=127.0.0.1
DB_PORT=5433
DB_USERNAME=postgres
DB_PASSWORD=
DB_NAME=loopp_db
TYPEORM_SYNCHRONIZE=true
THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=120

# Redis Configuration
REDIS_ENABLED=true
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_KEY_PREFIX=dongu:dev:
EVENT_RETRY_BATCH_SIZE=50

# Read-path Feature Flags
USE_REDIS_UNREAD_COUNT=false
USE_TIMESCALE_LEADERBOARD=false
USE_EVENT_BASED_METRICS=false

# Ops Endpoint Security
OPS_STATUS_TOKEN=

# Cloudinary Configuration
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
